SEO_KEYWORDS="smart order hotel, aplikasi smart order, qr code menu hotel, sistem pemesanan hotel, room service digital, archana app, archana smart order, qr menu hotel, digital menu hotel indonesia, smart ordering villa"
SEO_IMAGE=/images/landing/hero.png
